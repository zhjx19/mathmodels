library(tidyverse)
library(mathmodels)
sidp_model = function(parms, init, times) {
ode_solver(
y0 = init,
times = times,
equations = c(
S = "pi - (beta1 * I + beta2 * D + lambda * P) * S - mu * S",
I = "(beta1 * I + beta2 * D + lambda * P) * S - (mu + delta + gamma) * I",
R = "gamma * I - mu * R",
D = "(mu + delta) * I - b * D",
P = "sigma + xi * I + alpha * D - eta * P"
),
parms = parms
)
}
# 参数设置（$\mathcal{R}_0 \approx 0.705 < 1$）
parms_a = c(
pi    = 10,      # 易感者补充率
beta1 = 0.0005,  # 感染者接触率
beta2 = 0.001,   # 死者接触率
lambda = 0.00001,# 病毒接触率
mu    = 0.03,    # 自然死亡率
delta = 0.5,     # 因病死亡率
gamma = 0.02,    # 康复率
b     = 0.8,     # 埋葬率
sigma = 0,       # 病毒补充率
xi    = 0.0004,  # 感染者排毒率
alpha = 0.004,   # 死者排毒率
eta   = 0.03     # 病毒衰减率
)
result_a = sidp_model(
parms = parms_a,
init  = c(S = 330, I = 10, R = 0, D = 0, P = 0),
times = seq(0, 200, by = 0.5)
)
# 参数设置
parms_b = c(
pi    = 10,
beta1 = 0.006,
beta2 = 0.012,
lambda = 0.01,   # 病毒接触率大幅提高
mu    = 0.02,
delta = 0.9,     # 病死率更高
gamma = 0.06,    # 康复更快
b     = 0.8,
sigma = 0,
xi    = 0.04,    # 排毒率更高
alpha = 0.04,
eta   = 0.03
)
result_b = sidp_model(
parms = parms_b,
init  = c(S = 500, I = 10, R = 0, D = 0, P = 0),
times = seq(0, 200, by = 0.5)
)
plot_compartment(result_a, vars = c("S", "I", "D", "P"))
plot_compartment(result_b, vars = c("S", "I", "D"))
# 病毒浓度变化（对数尺度）
result_b |>
ggplot(aes(time, P)) +
geom_line(color = "#D55E00", linewidth = 1) +
scale_y_log10(labels = scales::label_scientific()) +
labs(
title = "环境病毒浓度 P(t)",
x = "时间 (天)", y = expression(P(t) ~ " (对数尺度)")
) +
theme_minimal()
