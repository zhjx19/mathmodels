cal_eg = function(s, x, h) {
if(h == 1) 0
else (sum((s-x)^2) / (1 - sum(x^2)) - h) / (1 - h)
}
H = data |>
summarise(h = HHI({{y}}, scaled = FALSE), .by = {{industry}})
X = data |>
summarise(x = sum({{y}}), .by = {{region}}) |>
mutate(x = x / sum(x))
S = data |>
summarise(s = sum({{y}}), .by = c({{region}}, {{industry}})) |>
mutate(s = s / sum(s), .by = {{industry}}) |>
pivot_wider(names_from = {{industry}}, values_from = s,
values_fill = 0)
map2_dbl(S[-1], H$h, function(s, h) cal_eg(s, X$x, h))
}
