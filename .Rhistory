# 参数
parms = c(
beta  = 0.3,      # 传播率
sigma = 0.2,      # 潜伏→感染
gamma = 0.1,      # 恢复率
omega = 0.05,     # 免疫丧失率
mu    = 0.01,     # 出生/死亡率
N     = 10000     # 总人口
)
# 仿真
seirs_result = ode_solver(
y0   = c(S = 9990, E = 0, I = 10, R = 0),
times = seq(0, 200, by = 0.5),
equations = c(
S = "-beta * S * I + omega * R + mu * N - mu * S",
E = "beta * S * I - sigma * E - mu * E",
I = "sigma * E - gamma * I - mu * I",
R = "gamma * I - omega * R - mu * R"
),
parms = parms
)
head(seirs_result)
plot_compartment(seirs_result, vars = c("S", "E", "I", "R"))
plot_infection_rate_rt(seirs_result, vars = c("S", "I"),
beta = 0.3, gamma = 0.1)
